listen_address = "localhost"
listen_port = 19827
template_texts = ["こんにちは！", "お疲れさまでした。失礼します。"]
log_file = "./log/voice_%%Y_%%m_%%d.log"
log_level = "INFO"
[[filters]]
pattern = "foo"
replaced = "bar"

[[filters]]
pattern = "嫌い"
replaced = "好き"

[recording]
enable = true
routes_list = [
    [
        "transcription",
        "subtitle",
    ],
    [
        "transcription",
        "translation",
        "subtitle_translated",
    ],
    [
        "transcription",
        "vc",
        "playback",
    ],
]
format = 4
channels = 1
rate = 16000
chunk = 12800
interval_sec = 0.8
silence_threshold = -45
max_recording_sec = 10.0
input_host_api_name = ""
input_device_name = ""
input_device_index = 0

[transcription]
enable = true
worker_type = "ACP"
transliterate_with_mozc = false
recording_log = false
recording_log_dir = "./reclog"
# Silero VAD スキップゲート (opt-in)。音声比率の低いチャンクを音声認識前に落とす
# (無音での whisper 幻聴・無駄な GPU 推論を防ぐ)。vc.vad_* とは独立した設定。既定 OFF。
# スキップされたチャンクは字幕・翻訳に流れず、recording_log にも記録されない。
vad_gate = false
# vc と同じ silero_vad.onnx (v6.2.1) を指す。
# vad_model_file = "~/.config/vstreamer/silero_vad.onnx"
# 注意: recording が 16kHz 以外で録るとき、ゲートの 16kHz 変換に PyAV が要る
# (whisper extra 同梱)。ACP/GCP のみで whisper extra 無しだと非 16kHz 入力では
# ゲートは無効化される (fail-open で素通し・警告1回)。recording.rate=16000 なら不要。
# speech 確率の閾値 (窓 32ms ごとにこれ以上で speech 扱い)。
vad_threshold = 0.5
# speech 窓の割合がこれ未満のチャンクは認識をスキップ (字幕・翻訳にも流れない)。
# 重要: この比率は「録音チャンク全体」に対する割合。recording は発話前の lookback
# (last_interval_frames_buffer) と gradual-stop の余韻で前後に無音を足すので、短い
# フィラー (「え」「うん」等) は比率が下がりやすい。既定 0.1 でも短い相槌が落ちること
# がある → フィラーを残したいなら低め (例 0.03-0.05) にする。
vad_min_speech_ratio = 0.1

[tts]
enable = true
worker_type = "VR2"

[playback]
enable = true
volume = "100"
output_host_api_name = ""
output_device_name = ""
output_device_index = 1

[subtitle]
enable = true
# "TK" = 専用ウィンドウを出す (ディスプレイが要る)。
# "OBS" = obs-websocket 経由で OBS の Text (GDI+) ソースへ送る (ディスプレイ不要)。
worker_type = "TK"
window_width = 1920
window_height = 120
bg_color = "systemTransparent"

# worker_type = "OBS" のときだけ使う。
# 事前に OBS 側で: Tools -> obs-websocket Settings で WebSocket サーバを有効にし、
# text_source の名前で Text (GDI+) ソースを作りシーンに配置しておくこと
# (vspeech はソースを作らずシーンにも触れない。ADR-0041)。
# 見た目は下の [subtitle.text] / [subtitle.translated] (+ window_width/height/bg_color)
# が権威で、OBS 側で手動変更しても接続確立時と reload 時に config の値で上書きされる。
[subtitle.obs]
url = "ws://127.0.0.1:4455"
password = ""
text_source = "vspeech-text"
# translation を使わないパイプラインでは空のままでよい -- その場合 OBS 側に
# このソースを用意する必要も無い。p=s の翻訳字幕は届かなくなる代わりに、
# 実際に届いたときだけ warn を1回出して継続する (ADR-0041 / 0042)。
translated_source = "vspeech-translated"

[translation]
enable = true
source_language_code = "ja"
target_language_code = "en"

[vc]
enable = true
# 入力音声の音量変化（抑揚）を出力へ転写する。既定 true。
adjust_output_vol_to_input_voice = true
# 転写の深さ 0(無効)..1(フル)。
envelope_strength = 1.0
# 適用ゲインのクランプ（ダック）。RVC 出力は既にフルスケールなので gain は 1.0 以下推奨:
# max_gain>1 は音の大きい部分を持ち上げて音割れ(クリップ)する。min_gain は無音時の下限。
min_gain = 0.1
max_gain = 1.0
# RMS エンベロープのフレーム長(ms)。小さいほど追従は速いが粗い。
volume_adjust_window_ms = 25.0
# Silero VAD ノイズゲート (opt-in)。非音声チャンクは RVC 推論ごとスキップし、
# 発話内の非音声区間 (ブレス・環境音) は出力をダックする。
vad_gate = false
# 入手: snakers4/silero-vad の silero_vad.onnx (v6.2.1, MIT)。取得してパスを指定する。
#   https://github.com/snakers4/silero-vad （ライセンス詳細は THIRD_PARTY_NOTICES.md）
# vad_model_file = "./silero_vad.onnx"
# speech 確率の閾値。窓 (32ms) ごとにこれ以上で speech 扱い。
vad_threshold = 0.5
# speech 窓の割合がこれ未満のチャンクは RVC をスキップ (playback に何も流れない)。
vad_min_speech_ratio = 0.1
# speech 区間の前後をこの ms だけ開けておく (子音の頭・語尾の食われ防止)。
vad_speech_pad_ms = 100.0
# 非音声区間の出力ゲイン。0.0 = 完全ミュート。
vad_min_gain = 0.0

[ami]
appkey = ""
engine_name = ""
engine_uri = ""
service_id = ""
request_timeout = 30.0
extra_parameters = "keepFillerToken=0"

[gcp]
service_account_file_path = ""
request_timeout = 3.0
max_retry_count = 5
retry_delay_sec = 0.1
location = "asia-northeast1"

[vr2]
voice_name = "akari_44"

[whisper]
model = "small"
no_speech_prob_threshold = 0.6
logprob_threshold = -1.0

[voicevox]
speaker_id = 2
# 0.16 では onnxruntime / 辞書 / .vvm モデルは wheel 同梱ではない。
# 公式ダウンローダ (uv run poe voicevox-assets) で取得し、各パスを指定する。
openjtalk_dir = "./voicevox/dict/open_jtalk_dic_utf_8-1.11"
model_dir = "./voicevox/models/vvms"
# voicevox 専用ビルドの onnxruntime。whisper/rvc の onnxruntime-gpu とは別物。
# 明示しないと誤った onnxruntime DLL を読み込む恐れがある。
onnxruntime_path = "./voicevox/onnxruntime/lib/voicevox_onnxruntime.dll"

[rvc]
# RVC 声モデル (自作 or 第三者モデル。第三者は各配布元の規約に従う)。利用者が用意する。
model_file = "./dummy_simple.onnx"
# 入手: hubert_base.pt (RVC 配布の ContentVec; origin auspicious3000/contentvec, MIT) を 2 段変換した
#   ONNX 資産ディレクトリを指す。手順は `uv run poe convert-hubert --help` / `uv run poe export-hubert-onnx --help`。
hubert_model_file = "./hubert_contentvec"
f0_up_key = 12
window = 160
quality = 0
gpu_id = 0
# f0 抽出器: "rmvpe"（既定）/ "fcpe" / "dio" / "harvest"
# dio/harvest は pyworld が必要（cp314 wheel が無いため runtime 依存から外した）。
# 使う場合のみ手動導入: uv pip install pyworld
# fcpe は rmvpe より高速だが精度は落ちる (ADR-0049)。手動DL不要 — 使う前に onnx を生成:
#   uv run poe export-fcpe-onnx --output ./fcpe.onnx  （詳細は同 --help）
f0_extractor_type = "rmvpe"
# rmvpe の重みファイル（f0_extractor_type = "rmvpe" のとき必要）
# 入手: wok000/weights_gpl の rmvpe_20231006.onnx (GPL-3.0 — 詳細は THIRD_PARTY_NOTICES.md 第3節)
#   https://huggingface.co/wok000/weights_gpl
rmvpe_model_file = "./rmvpe.onnx"
# fcpe の onnx（f0_extractor_type = "fcpe" のとき必要。uv run poe export-fcpe-onnx で生成）
fcpe_model_file = "./fcpe.onnx"

# ストリーミング VC (ADR-0050〜0054)。発話系 [vc]/[rvc] とは独立した
# 低遅延・連続(無音区切り無し)の VC。既定 OFF — 有効化すると、発話系パイプラインの
# コードは無改変のまま、別マイク入力 → 固定長ブロック VC → 別出力、が並行して常時走る。
# ただしこれは opt-in の機能であり、**プロセスは分離されない**:回復可能なデバイス/GPU の
# ヒカップはサブシステム内で自己回復するが、致命的(unrecoverable)な障害を起こすと
# プロセス全体を fail-loud で落とす(発話系も道連れになる)。VC を静かに失った半死の
# プロセスを避けるための意図した挙動なので、supervisor/daemon 前提で運用すること。
[stream_vc]
enable = false
# ★以下 block/context/crossfade は実機耳確認 (RTX 4060 Laptop / fcpe / 実声) で
#   詰めた値。160/500/25 が clean だと確認できた組み合わせ。
# 固定ブロック(hop)長 ms。160ms = 片道 ~199ms (p50 推論 35.3ms, RTF 0.24) で clean。
# 80ms は片道 ~119ms と速いが、seam のプチプチ(クリック)が可聴なので推奨しない。
block_ms = 160.0
# rolling 左文脈長 ms。HuBERT/f0 抽出の文脈として block の前に付ける実音声の長さ
# (reflect-pad ではなく実データ、ADR-0053)。crossfade_ms 以上にすること。
# 耳確認: 500ms 未満だとガタガタ鳴る(100ms は「ガタゴト」が常時乗る)。
# 500ms 超 (2000ms を試験) にしても改善しないので、500ms が実用上の底。
context_ms = 500.0
# 等電力クロスフェード帯 ms。block_ms 未満 かつ context_ms 以下が必須
# (満たさないと preflight/起動時にエラー)。25ms が耳確認済みの値。
crossfade_ms = 25.0
# ※これらの数値は対象 GPU に依存する。別のマシンへ持っていくときは
#   `uv run poe stream-vc-rtf` で per-block RTF を測り直してから決めること。
#   ただしこのハーネスが読むのは **[rvc] セクションだけ**で、[stream_vc.rvc] は見ない。
#   streaming 用のモデル/f0 抽出器を測りたいときは、[rvc] を [stream_vc.rvc] と同じ内容に
#   写した config を用意して、それを --config に渡すこと。
# SOLA(位相合わせ)の探索半幅 ms。0 で無効。RVC デコーダはステートレスなので、
# 同じ入力区間でも tick ごとに数 ms 位相のずれた波形を返す(実測: lag0 の相関 -0.02 に
# 対し最適 lag では 0.89)。混ぜる前に相互相関で位置を合わせる。emit 長は固定のまま
# なのでドリフトはせず、代償はこの値ぶんの遅延だけ。実測上 5ms で足りる。
sola_search_ms = 5.0

# --- VAD ノイズゲート (既定 off) ---
# off だと streaming 経路は無音でも回り続け、**部屋のノイズフロアがそのまま RVC を
# 通り、しかも増幅されて**鳴り続ける(実測: 入力 RMS 0.000298 -> 出力 0.0204 =
# +10〜+37dB、context 100ms 時)。発話系 [vc] の VAD ゲートは speech chunk 単位で
# 動くもので streaming には効かないので、これは別のゲート。
# モデルは [vc] とまったく同じ silero_vad.onnx (v6.2.1) を使ってよい。
vad_gate = false
vad_model_file = "./silero_vad.onnx"
# speech と判定する窓確率の閾値。ブロック内の窓確率の **最大値** と比較する
# (160ms ブロック = 32ms 窓 5 個ぶん。1 窓でも speech なら開けて発話頭を落とさない)。
vad_threshold = 0.5
# 最後に speech と判定してからゲートを開けたまま保つ時間 ms。語間の短い無音で
# ゲートがバタつく(ブロック粒度 = 160ms なら 6.25Hz の chattering)のを防ぐ。
vad_hangover_ms = 300.0
# ゲートが閉じたときの出力ゲイン。0.0 = 完全ミュート。わずかに残したいなら 0.05 等。
vad_min_gain = 0.0
# 実装メモ: ゲートが閉じていても **推論はスキップしない**。StreamingVc は rolling
# 左文脈とクロスフェード tail を持つステートフル変換なので、ブロックを飛ばすと文脈に
# 穴が開き、発話が再開したときの seam が壊れる。減衰するのは emit する音だけで、
# ゲインはブロック内で線形に ramp する(境界で階段状に変えるとそれ自体がクリックになる)。
# VAD が実行時に失敗したときは音を素通しし(fail-open)、警告は 1 回だけ出す。

# 発話系 [recording] とは別に開くマイク入力 (ADR-0052: 二重独立キャプチャ。
# 発話系 recording は無改変のまま別途マイクを開く)。未指定(空)ならシステム既定入力。
input_host_api_name = ""
input_device_name = ""
input_device_index = 0

# 出力デバイス。[playback] とは別に開く。未指定(空)ならシステム既定出力。
output_host_api_name = ""
output_device_name = ""
output_device_index = 1

# トランスポート種別。現状は同一プロセス内直結の "in_process" のみ(単一マシン内で完結)。
# マシン分離用の段階的トランスポート (ADR-0051 の T1 unary gRPC / T3 生ソケット) は未実装。
transport_type = "in_process"
# capture -> VC 間の橋渡しキューの上限ブロック数。VC が詰まって溢れたら
# 最古のブロックを drop する (drop は telemetry に記録される)。
max_queued_blocks = 8

# ストリーミング専用の RVC モデル設定。[rvc] とは完全に独立したモデルを指せる
# (ADR-0054)。f0_up_key/window など未記載のフィールドは [rvc] と同じ意味を持ち、
# 省略時はコードの既定値 (f0_up_key=0, window=160) が使われる。
# quality (reflect-pad の折返し量) はここでは無視される — StreamingVc は
# context_ms による実データ左文脈を使うため N/A。
[stream_vc.rvc]
# ★ここは発話系 [rvc] と独立した設定。個別にフィールドを拾うのではなく、
#   **動いている [rvc] セクションを丸ごとコピーしてから streaming 用に調整する**こと。
#   拾い漏らすと「声としては出るが扇風機のような唸りが乗る」等、原因の分かりにくい
#   壊れ方をする(f0_up_key の写し忘れで実際に踏んだ)。
model_file = "./dummy_simple.onnx"
hubert_model_file = "./hubert_contentvec"
gpu_id = 0
# ★ピッチシフト(半音)。入力話者のピッチをモデルが学習した話者のピッチ域へ合わせる値。
#   **発話系 [rvc] と同じ値にすること**(この例では上の [rvc] に合わせて 12)。
#   同じモデルなのに既定 0 のまま使うと、モデルの想定から外れた f0 を NSF ハーモニック源に
#   与えることになり、出力が唸って扇風機のようなノイズになる。
f0_up_key = 12
# 発話系と同じくマイクゲインとして適用される。
input_boost = 1.0
# 推奨: streaming では "fcpe" ([rvc] 既定の "rmvpe" より 1 推論あたりが軽く、
# ブロックごとに毎回走る streaming では効く。実機耳確認もこの構成で行った)。
# なお「最小入力長」の制約を持つのは fcpe の方 (焼き込んだ reflect-pad が 433
# サンプル ≈ 27ms を要求する) だが、runtime が左ゼロパッドで底上げするので
# 短いブロックでも落ちない。rmvpe にはこの制約は無い。
f0_extractor_type = "fcpe"
fcpe_model_file = "./fcpe.onnx"
# f0_extractor_type = "rmvpe" にする場合のみ必要:
# rmvpe_model_file = "./rmvpe.onnx"

[subtitle.text]
display_sec_per_letter = 0.4
min_display_sec = 6.0
max_text_len = 32
# tk のポイント単位。正=ポイント/負=ピクセル (tk 自体の符号規約)。OBS backend
# は同じ値から自動で見た目を揃える (ADR-0044) -- 手で単位を変える必要は無い。
font_size = 24
font_family = "Meiryo UI"
font_style = "bold"
font_color = "#ffffff"
outline_color = "#000000"

[subtitle.translated]
display_sec_per_letter = 0.2
min_display_sec = 6.0
max_text_len = 40
font_size = 22
font_family = "Meiryo UI"
font_style = "bold"
font_color = "#ffffff"
outline_color = "#000000"

[gcp.service_account_info]

[vr2.params]
volume = 1.0
speed = 1.0
pitch = 1.0
emphasis = 1.0
pause_middle = 150.0
pause_long = 370.0
pause_sentence = 800.0
master_volume = 1.0

[voicevox.params]
speed_scale = 1.0
pitch_scale = 0.0
intonation_scale = 1.0
volume_scale = 1.0
pre_phoneme_length = 0.1
post_phoneme_length = 0.1

[telemetry]
enable = true
max_samples = 5000
log_raw_e2e = true
# 発話→再生の真E2Eはマシン間で time.time() を比較するため、各マシンの
# 時計をNTPで同期しておくこと。未同期だと負値/極端値となる。
# e2e の扱いは2段階:
#  - e2e > skew_warn_threshold: 再生キューのバックログ/長尺発話とみなし WARNING を
#    出すが、記録は残す(tail レイテンシをテレメトリから消さないため)。
#  - e2e < 0、または e2e > skew_hard_ceiling_sec: 非現実的な値=時計ズレ疑いとして
#    WARNING を出し、記録しない(テレメトリ汚染を防ぐ)。
# skew_warn_threshold は正規の最大e2e(発話長 + 処理 + コールドスタート)より少し上に。
# 注意: 数秒程度の小さなズレはコールドスタートと区別できず素通りする(根本はNTP同期)。
skew_warn_threshold = 10.0
# これを超える(または負値の)e2e だけを「時計ズレ疑い」として破棄する上限(秒)。
# 前方への大きなズレ(例: W32Time停止で数十秒先行)を捕捉する用。正規のバックログ
# (連続発話時の十数秒)より十分大きく取ること。
skew_hard_ceiling_sec = 60.0
# 1発話ごとの各段所要時間+E2Eを JSONL で記録する出力先。空=無効（既定）。
# %%Y 等の日付パターン可。Windows/UNC ネットワークパスは TOML の
# シングルクォート(リテラル文字列)で書くこと（ダブルクォートだと \d 等が壊れる）:
#   jsonl_path = '\\<NAS_HOST>\d\vs\tel_%%Y%%m%%d.jsonl'
jsonl_path = ""
